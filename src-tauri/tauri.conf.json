{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "WindGifs",
  "version": "0.2.1",
  "identifier": "com.bneog.windgifs",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "WindGifs",
        "width": 1120,
        "height": 900,
        "minWidth": 1120,
        "minHeight": 900,
        "maxWidth": 1120,
        "maxHeight": 900,
        "resizable": false,
        "maximizable": false,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$HOME/**"
        ]
      },
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "../tools/ffmpeg/",
      "icons/icon.ico"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "installerHooks": "windows/nsis-hooks.nsh"
      }
    }
  }
}
